# Database
DATABASE_URL=postgresql://tmgboard:tmgboard@localhost:5432/tmg_board

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# DocuSign (get from DocuSign Developer Portal)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_PRIVATE_KEY_PATH=./keys/docusign_private.pem
DOCUSIGN_HMAC_KEY=

# S3 Storage (optional - defaults to local)
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
S3_BUCKET=tmg-board-documents

# App
BASE_URL=http://localhost:3011
DEBUG=true
