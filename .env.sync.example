# TMG Board: Production → Staging Sync Configuration
#
# Copy this file to .env.sync and fill in the values.
# Get connection strings from Railway dashboard → service → Variables → DATABASE_URL
#
# Usage: ./scripts/sync-prod-to-staging.sh

# Required: Database connection strings
PROD_DATABASE_URL=postgresql://postgres:PASSWORD@HOST.railway.internal:5432/railway
STAGING_DATABASE_URL=postgresql://postgres:PASSWORD@HOST.railway.internal:5432/railway

# Optional: Railway service IDs for file sync (uploads volume)
# Get these from: railway service list
# PROD_SERVICE_ID=
# STAGING_SERVICE_ID=
